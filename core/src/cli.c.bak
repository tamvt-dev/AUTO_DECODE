#include <stdio.h>
#include <string.h>
#include <glib.h>
#include "../include/core.h"
#include "../include/version.h"
#include "../include/logging.h"

static gboolean verbose = FALSE;
static int max_depth = 1;

static void print_result(DecodeResult *result) {
    if (result->error_code == ERROR_OK && result->output) {
        printf("%s\n", result->output);
        
        if (verbose) {
            fprintf(stderr, "\n[Metadata]\n");
            fprintf(stderr, "  Format:      %s\n", result->format);
            fprintf(stderr, "  Time:        %.2f ms\n", result->processing_time_ms);
            fprintf(stderr, "  Input size:  %zu bytes\n", result->input_size);
            fprintf(stderr, "  Output size: %zu bytes\n", result->output_size);
            fprintf(stderr, "  From cache:  %s\n", result->from_cache ? "yes" : "no");
            if (result->decode_depth > 0) {
                fprintf(stderr, "  Depth:       %d\n", result->decode_depth);
            }
        }
    } else {
        fprintf(stderr, "Error: %s\n", result->error_message ? result->error_message : "Unknown");
    }
}

int main(int argc, char *argv[]) {
    GOptionContext *context;
    GError *error = NULL;
    
    static gboolean version = FALSE;
    static gboolean help = FALSE;
    
    GOptionEntry entries[] = {
        {"version", 'v', 0, G_OPTION_ARG_NONE, &version, "Show version", NULL},
        {"help", 'h', 0, G_OPTION_ARG_NONE, &help, "Show help", NULL},
        {"verbose", 'V', 0, G_OPTION_ARG_NONE, &verbose, "Verbose output", NULL},
        {"depth", 'd', 0, G_OPTION_ARG_INT, &max_depth, "Max decode depth", "N"},
        {NULL}
    };
    
    context = g_option_context_new("[INPUT] - HyperDecode CLI");
    g_option_context_add_main_entries(context, entries, NULL);
    
    if (!g_option_context_parse(context, &argc, &argv, &error)) {
        fprintf(stderr, "Error: %s\n", error->message);
        return 1;
    }
    
    if (version) {
        printf("%s version %s\n", APP_NAME, APP_VERSION);
        return 0;
    }
    
    if (help || argc < 2) {
        printf("HyperDecode v%s - Professional Encoding/Decoding Tool\n\n", APP_VERSION);
        printf("Usage: %s [OPTIONS] [INPUT]\n\n", argv[0]);
        printf("Options:\n");
        printf("  -v, --version     Show version\n");
        printf("  -h, --help        Show this help\n");
        printf("  -V, --verbose     Verbose output\n");
        printf("  -d, --depth N     Max decode depth (default: 1)\n\n");
        printf("Examples:\n");
        printf("  %s SGVsbG8gV29ybGQ=\n", argv[0]);
        printf("  echo SGVsbG8= | %s\n", argv[0]);
        printf("  %s -d 3 \"U0dWc2JHRnVZV2xr\"\n", argv[0]);
        return 0;
    }
    
    log_init(verbose ? LOG_LEVEL_DEBUG : LOG_LEVEL_WARN, NULL, TRUE);
    core_init();
    
    const char *input = argv[1];
    DecodeResult *result = core_decode_recursive(input, max_depth);
    print_result(result);
    decode_result_free(result);
    
    core_cleanup();
    log_close();
    
    return 0;
}
